import numpy as np
import matplotlib.pyplot as plt
from scipy.optimize import curve_fit
from modelo_harmonico import pesos_harmonicos

def survival_prob(t, alpha, lambda0=1.0, n_max=20000):
    """Probabilidade de sobrevivência P(t) = Σ w_n exp(-λ0 t / n) / Z."""
    n = np.arange(1, n_max+1)
    w, Z = pesos_harmonicos(alpha, n_max)
    exp_term = np.exp(-lambda0 * t / n)
    return np.dot(w, exp_term) / Z

def lei_potencia(t, A, expoente):
    return A * t ** expoente

if __name__ == "__main__":
    alpha = 1.5
    t = np.logspace(-2, 2, 200)   # tempo em unidades de 1/λ0
    P = survival_prob(t, alpha, lambda0=1.0, n_max=20000)

    # Ajuste da cauda (t > 3)
    mask = t > 3
    t_tail = t[mask]
    P_tail = P[mask]
    popt, _ = curve_fit(lei_potencia, t_tail, P_tail, p0=[0.1, -2.0])
    expoente = popt[1]

    # Plot
    plt.figure()
    plt.loglog(t, P, label=f'Modelo α={alpha}')
    plt.loglog(t, np.exp(-t), 'k--', label='Exponencial pura')
    plt.loglog(t_tail, lei_potencia(t_tail, *popt), 'r:', label=f'Potência ~ t^{expoente:.2f}')
    plt.xlabel('Tempo (1/λ₀)')
    plt.ylabel('Probabilidade de sobrevivência')
    plt.legend()
    plt.title('Decaimento radioativo harmônico')
    plt.grid(True)
    plt.show()
    print(f"Expoente de cauda medido: {expoente:.3f} (esperado {-(2*alpha-1):.3f})")

