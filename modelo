import numpy as np
import matplotlib.pyplot as plt
from scipy.fft import fft, fftfreq

def cmb_spectrum_modulado(ell, ell0=200, epsilon=0.03, beta=1.5):
    """Retorna C_ℓ modulado: C_ℓ = C_ℓ^ΛCDM * (1 + ε cos(2πℓ/ℓ0) ℓ^{-β})"""
    # Aqui usamos um modelo sintético para C_ℓ^ΛCDM (apenas para demonstração)
    C_lcdm = 1e-9 / (ell * (ell+1))**0.5   # formato grosseiro
    mod = 1 + epsilon * np.cos(2 * np.pi * ell / ell0) * (ell ** (-beta))
    return C_lcdm * mod

if __name__ == "__main__":
    ell = np.arange(2, 2000)
    C_ell = cmb_spectrum_modulado(ell, ell0=200, epsilon=0.02, beta=1.5)

    # Resíduo após subtrair o fundo suave (aqui usamos uma suavização simples)
    from scipy.ndimage import gaussian_filter1d
    C_smooth = gaussian_filter1d(C_ell, sigma=50)
    residuo = C_ell - C_smooth

    # Análise de Fourier do resíduo
    fft_vals = fft(residuo)
    freqs = fftfreq(len(ell), d=1)
    power = np.abs(fft_vals)**2

    plt.figure(figsize=(10,4))
    plt.subplot(1,2,1)
    plt.plot(ell, residuo)
    plt.xlabel('ℓ')
    plt.ylabel('Resíduo C_ℓ')
    plt.title('Modulação harmônica residual')
    plt.grid(True)

    plt.subplot(1,2,2)
    mask = freqs > 0
    plt.plot(freqs[mask], power[mask])
    plt.xlabel('Frequência (1/ℓ)')
    plt.ylabel('Potência espectral')
    plt.xlim(0, 0.02)
    plt.axvline(1/200, color='r', linestyle='--', label='1/ℓ₀')
    plt.legend()
    plt.title('Detecção de periodicidade')
    plt.tight_layout()
    plt.show()

