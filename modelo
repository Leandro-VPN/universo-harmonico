import numpy as np
from scipy.special import zeta

# Constantes
PHI = (np.sqrt(5) - 1) / 2   # razão áurea

def pesos_harmonicos(alpha, n_max):
    """Retorna array de pesos w_n = n^{-2*alpha} e sua soma."""
    n = np.arange(1, n_max+1)
    w = n ** (-2*alpha)
    return w, w.sum()

def theta_n_golden(n):
    """Fase uniforme usando razão áurea."""
    return 2 * np.pi * (n * PHI % 1)

def omega_theta(theta, omega0=1.0, p=1.35):
    """Mapeamento angular -> frequência: ω = ω₀ * (tan(θ/2))**p."""
    if theta <= 0:
        return 0.0
    if theta >= np.pi:
        return np.inf
    return omega0 * (np.tan(theta/2) ** p)

def lorentz_response(omega_n, omega_theta, gamma):
    """Amplitude complexa do filtro Lorentziano."""
    return gamma / (gamma + 1j*(omega_n - omega_theta))

def correlacao_super_hibrida(theta1, theta2, alpha, gamma, k, p,
                             A=1.0, B=-0.31, C=1.67, D=1.09, delta=0.28,
                             omega0=1.0, n_max=20000):
    """
    Retorna a correlação C(θ1, θ2) segundo o modelo super-híbrido.
    α=1.5 fixo; demais parâmetros podem ser passados.
    """
    n = np.arange(1, n_max+1)
    w, norm = pesos_harmonicos(alpha, n_max)
    omega_n = n * omega0
    w1 = omega_theta(theta1, omega0, p)
    w2 = omega_theta(theta2, omega0, p)

    # Termo de batimento (C_bat)
    th_n = theta_n_golden(n)
    C_bat = np.sum(w * np.cos(k * (th_n - theta2) + delta)) / norm

    # Termo de produto com sinal (-1)^n
    A1sq = gamma**2 / (gamma**2 + (omega_n - w1)**2)
    A2sq = gamma**2 / (gamma**2 + (omega_n - w2)**2)
    sinal = (-1) ** n
    C_prod = np.sum(w * sinal * A1sq * A2sq) / norm

    # Termo de fase (diferença de fase)
    phi1 = -np.arctan2((omega_n - w1), gamma)
    phi2 = -np.arctan2((omega_n - w2), gamma)
    C_fase = np.sum(w * np.cos(phi1 - phi2)) / norm

    # Combinação linear
    C_total = A * C_bat + B * C_prod + C * C_fase
    return D * C_total

