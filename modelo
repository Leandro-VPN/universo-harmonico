import numpy as np
from scipy.optimize import differential_evolution
from modelo_harmonico import correlacao_super_hibrida

def erro_modelo(params, theta_grid, target, alpha=1.5, n_max=10000):
    """
    params = [gamma, k, p, B, C, D, delta]
    """
    gamma, k, p, B, C, D, delta = params
    # limites básicos para evitar valores inviáveis
    if gamma <= 0.1 or k <= 0.1 or p <= 0.1:
        return 1e10
    C_model = np.array([
        correlacao_super_hibrida(0, th, alpha, gamma, k, p,
                                 A=1.0, B=B, C=C, D=D, delta=delta,
                                 n_max=n_max)
        for th in theta_grid
    ])
    rmse = np.sqrt(np.mean((C_model - target)**2))
    return rmse

if __name__ == "__main__":
    # Grade de ângulos (31 pontos de 0 a pi)
    theta_grid = np.linspace(0, np.pi, 31)
    target = -np.cos(theta_grid)   # curva quântica

    # Limites da otimização: (gamma, k, p, B, C, D, delta)
    bounds = [(0.5, 30.0), (0.5, 20.0), (0.5, 5.0),
              (-3.0, 3.0), (-3.0, 3.0), (0.5, 1.5),
              (0.0, 2*np.pi)]

    # Otimização por evolução diferencial
    result = differential_evolution(erro_modelo, bounds,
                                    args=(theta_grid, target, 1.5, 10000),
                                    maxiter=100, popsize=15, seed=42,
                                    disp=True)
    print("Melhores parâmetros encontrados:")
    print(f"γ = {result.x[0]:.4f}")
    print(f"k = {result.x[1]:.4f}")
    print(f"p = {result.x[2]:.4f}")
    print(f"B = {result.x[3]:.4f}")
    print(f"C = {result.x[4]:.4f}")
    print(f"D = {result.x[5]:.4f}")
    print(f"δ = {result.x[6]:.4f} rad")
    print(f"RMSE = {result.fun:.5f}")

