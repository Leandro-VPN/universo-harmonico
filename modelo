import numpy as np
import matplotlib.pyplot as plt
from modelo_harmonico import correlacao_super_hibrida

def plot_correlacao(alpha=1.5, gamma=11.4, k=5.82, p=1.35,
                    B=-0.31, C=1.67, D=1.09, delta=0.28,
                    n_max=20000):
    theta = np.linspace(0, np.pi, 200)
    C_model = [correlacao_super_hibrida(0, th, alpha, gamma, k, p,
                                        1.0, B, C, D, delta,
                                        n_max=n_max) for th in theta]
    C_qm = -np.cos(theta)

    plt.figure(figsize=(8,5))
    plt.plot(theta/np.pi, C_qm, 'k-', linewidth=2, label='QM: -cos(θ)')
    plt.plot(theta/np.pi, C_model, 'r-', alpha=0.8, label='Modelo harmônico (α=1.5)')
    plt.xlabel('θ / π')
    plt.ylabel('Correlação <AB>')
    plt.legend()
    plt.grid(True)
    plt.title('Correlação Bell – Modelo vs QM')
    plt.show()

    # Resíduos
    residuo = np.array(C_model) - C_qm
    plt.figure()
    plt.plot(theta/np.pi, residuo, 'b-')
    plt.xlabel('θ / π')
    plt.ylabel('Resíduo (Modelo - QM)')
    plt.title('Estrutura fina harmônica')
    plt.grid(True)
    plt.show()

if __name__ == "__main__":
    plot_correlacao()

